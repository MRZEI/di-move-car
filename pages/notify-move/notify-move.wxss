@import "/style/shared.wxss";

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

/* 状态栏 */
.status-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-lg);
}

.status-time {
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-text-primary);
}

.status-icons {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.signal-icon {
  width: 12px;
  height: 12px;
  border-radius: 2px;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFFFF 50%, transparent 50%);
  border: 1px solid rgba(255, 255, 255, 0.4);
  position: relative;
}

.signal-icon::before {
  content: '';
  position: absolute;
  top: 2px;
  left: 2px;
  width: 6px;
  height: 6px;
  background: #FFFFFF;
}

.wifi-icon {
  width: 14px;
  height: 10px;
  position: relative;
}

.wifi-icon::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  background: #FFFFFF;
  border-radius: 50%;
}

.wifi-icon::after {
  content: '';
  position: absolute;
  bottom: 4px;
  left: 50%;
  transform: translateX(-50%);
  width: 10px;
  height: 5px;
  border: 1px solid #FFFFFF;
  border-bottom: none;
  border-radius: 10px 10px 0 0;
}

.battery-icon {
  width: 22px;
  height: 10px;
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: 2px;
  position: relative;
  display: flex;
  align-items: center;
}

.battery-icon::before {
  content: '';
  position: absolute;
  right: -3px;
  top: 50%;
  transform: translateY(-50%);
  width: 2px;
  height: 5px;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 0 1px 1px 0;
}

.battery-icon::after {
  content: '';
  position: absolute;
  left: 2px;
  top: 2px;
  bottom: 2px;
  width: 14px;
  background: var(--state-success);
  border-radius: 1px;
}

/* 页面头部 */
.page-header {
  padding: var(--space-lg) var(--space-lg) var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.page-title {
  font-size: var(--font-size-2xl);
  color: var(--color-text-primary);
  line-height: var(--line-height-2xl);
}

.page-subtitle {
  font-size: var(--font-size-sm);
  line-height: var(--line-height-sm);
}

/* 筛选标签栏 */
.filter-tabs {
  padding: var(--space-sm) 0;
  margin-bottom: var(--space-sm);
}

.filter-tabs-inner {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: 0 var(--space-lg);
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  padding: 0 var(--space-lg);
  border-radius: var(--radius-full);
  background-color: var(--color-bg-elevated);
  border: 1px solid var(--color-border);
  flex-shrink: 0;
  position: relative;
}

.filter-btn.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.filter-btn.active .filter-btn-text {
  color: var(--color-primary-text);
  font-weight: var(--font-weight-medium);
}

.filter-btn-text {
  font-size: 13px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.red-dot {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 6px;
  height: 6px;
  background-color: var(--state-error);
  border-radius: 50%;
}

/* 通知列表 */
.notification-list {
  flex: 1;
  padding: 0 var(--space-lg);
}

/* 通知卡片 */
.notification-card {
  background-color: var(--color-bg-surface);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
  border-left: 3px solid transparent;
  overflow: hidden;
}

.notification-card.card-border-urgent {
  border-left-color: var(--state-error);
}

.notification-card.card-border-warning {
  border-left-color: var(--state-warning);
}

.notification-card.card-border-success {
  border-left-color: var(--state-success);
}

.notification-card.card-border-info {
  border-left-color: var(--state-info);
}

.card-content {
  padding: var(--space-lg);
}

.card-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.card-time {
  font-size: var(--font-size-xs);
  line-height: var(--line-height-xs);
}

/* 标签样式 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
}

.badge-red {
  background-color: rgba(248, 113, 113, 0.15);
}

.badge-red .badge-text {
  color: var(--state-error);
}

.badge-warning {
  background-color: rgba(251, 191, 36, 0.15);
}

.badge-warning .badge-text {
  color: var(--state-warning);
}

.badge-success {
  background-color: rgba(52, 211, 153, 0.15);
}

.badge-success .badge-text {
  color: var(--state-success);
}

.badge-info {
  background-color: rgba(96, 165, 250, 0.15);
}

.badge-info .badge-text {
  color: var(--state-info);
}

.badge-text {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  line-height: var(--line-height-xs);
}

/* 卡片标题 */
.card-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: var(--line-height-base);
  display: block;
  margin-bottom: var(--space-xs);
}

/* 位置信息 */
.card-location {
  margin-top: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.card-location-text {
  font-size: var(--font-size-sm);
  line-height: var(--line-height-sm);
}

/* 状态行 */
.card-status-row {
  margin-top: var(--space-sm);
}

.card-status {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
}

.status-urgent {
  color: var(--state-error);
}

.status-warning {
  color: var(--state-warning);
}

.status-success {
  color: var(--state-success);
}

.status-info {
  color: var(--state-info);
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3xl) 0;
}

.empty-state-text {
  font-size: var(--font-size-base);
  line-height: var(--line-height-base);
}

/* 底部标签栏 */
.tab-bar {
  margin-top: auto;
}
