/* profile-qr.wxss - 挪车二维码页面样式 */

@import "/style/shared.wxss";

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 0;
  padding-bottom: calc(83px + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

/* Status Bar */
.status-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  background: transparent;
  flex-shrink: 0;
}

.status-bar-time {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: #FFFFFF;
}

.status-bar-icons {
  display: flex;
  align-items: center;
  gap: 6px;
}

.status-icon {
  width: 16px;
  height: 12px;
}

/* Main Content */
.main-content {
  flex: 1;
  padding: 0 var(--space-lg);
  padding-bottom: 83px;
}

/* Profile Header */
.profile-header {
  padding: 24px 0 0;
  text-align: center;
}

.avatar-wrapper {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-full);
  background: var(--color-bg-elevated);
  border: 2px solid var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-name {
  display: block;
  margin-top: 12px;
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.3;
}

.user-phone {
  display: block;
  margin-top: 4px;
  font-size: 13px;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.verified-badge {
  display: inline-block;
  margin-top: 8px;
  padding: 2px 10px;
  border-radius: var(--radius-full);
  background: rgba(232, 255, 0, 0.12);
}

.verified-text {
  font-size: 11px;
  color: #E8FF00;
  font-weight: var(--font-weight-medium);
}

/* Card base styles */
.card {
  background-color: var(--color-bg-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-top: var(--space-lg);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.card-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.card-action {
  font-size: 13px;
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.card-action.primary {
  color: var(--color-primary);
}

/* Vehicles Card */
.vehicles-card {
  margin-top: 20px;
}

.vehicle-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
}

.vehicle-icon-wrapper {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  background: rgba(232, 255, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.vehicle-info {
  flex: 1;
}

.vehicle-plate {
  display: block;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.vehicle-type {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 2px;
}

.divider {
  height: 1px;
  background-color: var(--color-divider);
}

/* QR Code Section */
.qr-section {
  margin-top: 10px;
  padding: var(--space-2xl);
}

.qr-description {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  line-height: 1.5;
  margin-bottom: 16px;
}

.qr-display-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-container {
  width: 200px;
  height: 200px;
  background: var(--color-bg-elevated);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* QR Grid - 7x7 grid of lime squares */
.qr-grid {
  display: grid;
  grid-template-columns: repeat(7, 20px);
  grid-template-rows: repeat(7, 20px);
  gap: 3px;
}

.qr-cell {
  width: 20px;
  height: 20px;
  border-radius: 2px;
}

.qr-cell.filled {
  background-color: #E8FF00;
}

.qr-cell.empty {
  background-color: transparent;
}

.qr-plate {
  margin-top: 12px;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  text-align: center;
}

.qr-hint {
  margin-top: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-align: center;
}

/* QR Button Row */
.qr-button-row {
  display: flex;
  gap: 10px;
  margin-top: 16px;
}

.btn {
  flex: 1;
  height: 44px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-outline {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.btn-outline-text {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.btn-primary-solid {
  background: var(--color-primary);
  border: none;
}

.btn-primary-solid-text {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: #181818;
}

/* QR Tips */
.qr-tips {
  display: block;
  margin-top: 12px;
  font-size: 11px;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

/* Statistics Card */
.stats-card {
  margin-top: 10px;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 18px;
  font-weight: var(--font-weight-bold);
  color: #E8FF00;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 11px;
  color: var(--color-text-tertiary);
  margin-top: 4px;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background-color: var(--color-divider);
}

/* Settings Card */
.settings-card {
  margin-top: 10px;
  padding: 0;
  overflow: hidden;
}

.settings-item {
  height: 48px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.settings-label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.settings-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.settings-arrow {
  flex-shrink: 0;
}

/* Toggle Switch */
.toggle-switch {
  width: 44px;
  height: 24px;
  border-radius: var(--radius-full);
  background: var(--color-border-strong);
  position: relative;
  cursor: pointer;
  transition: background var(--transition-fast);
  flex-shrink: 0;
}

.toggle-switch.active {
  background: var(--color-primary);
}

.toggle-switch::after {
  content: '';
  position: absolute;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #fff;
  top: 2px;
  left: 2px;
  transition: transform var(--transition-fast);
}

.toggle-switch.active::after {
  transform: translateX(20px);
  background: var(--color-primary-text);
}

/* Logout */
.logout-wrapper {
  margin-top: 20px;
  padding: 8px 0 24px;
  text-align: center;
}

.logout-text {
  font-size: var(--font-size-base);
  color: var(--color-text-tertiary);
  cursor: pointer;
}
