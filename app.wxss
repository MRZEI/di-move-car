/* DI挪车 - Global Styles */

page {
  --color-primary: #E8FF00;
  --color-background: #0A0A0A;
  --color-surface: #141414;
  --color-elevated: #1C1C1E;
  --color-text-primary: #FFFFFF;
  --color-text-secondary: rgba(255, 255, 255, 0.6);
  --color-text-tertiary: rgba(255, 255, 255, 0.36);
  --color-border: rgba(255, 255, 255, 0.08);
  --color-success: #34D399;
  --color-warning: #FBBF24;
  --color-error: #F87171;
  --color-info: #60A5FA;

  --font-family: "SF Pro Display", "PingFang SC", system-ui, -apple-system, sans-serif;

  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 14px;
  --radius-xl: 16px;
  --radius-full: 9999px;

  background-color: var(--color-background);
  color: var(--color-text-primary);
  font-family: var(--font-family);
  font-size: 14px;
  line-height: 1.5;
}

/* Container */
.container {
  min-height: 100vh;
  background-color: var(--color-background);
  padding: 16px;
  box-sizing: border-box;
}

/* Card */
.card {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid var(--color-border);
}

.card-elevated {
  background-color: var(--color-elevated);
  border-radius: var(--radius-lg);
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid var(--color-border);
}

/* Button */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 24px;
  border-radius: var(--radius-md);
  font-size: 16px;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
  border: none;
  outline: none;
}

.btn-primary {
  background-color: var(--color-primary);
  color: #0A0A0A;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background-color: var(--color-surface);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
}

.btn-secondary:active {
  background-color: var(--color-elevated);
}

.btn-disabled {
  background-color: var(--color-surface);
  color: var(--color-text-tertiary);
  border: 1px solid var(--color-border);
  pointer-events: none;
}

/* Input */
.input {
  width: 100%;
  padding: 12px 16px;
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-text-primary);
  font-size: 16px;
  font-family: var(--font-family);
  box-sizing: border-box;
  outline: none;
  transition: border-color 0.2s ease;
}

.input:focus {
  border-color: var(--color-primary);
}

.input::placeholder {
  color: var(--color-text-tertiary);
}

.input-disabled {
  background-color: var(--color-elevated);
  color: var(--color-text-secondary);
  pointer-events: none;
}

/* Text */
.text-primary {
  color: var(--color-text-primary);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-tertiary {
  color: var(--color-text-tertiary);
}

.text-primary-color {
  color: var(--color-primary);
}

.text-success {
  color: var(--color-success);
}

.text-warning {
  color: var(--color-warning);
}

.text-error {
  color: var(--color-error);
}

.text-info {
  color: var(--color-info);
}

/* Title */
.title {
  font-size: 24px;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8px;
}

.subtitle {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 4px;
}

/* Divider */
.divider {
  height: 1px;
  background-color: var(--color-border);
  margin: 16px 0;
}

/* Badge */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4px 8px;
  border-radius: var(--radius-full);
  font-size: 12px;
  font-weight: 500;
}

.badge-primary {
  background-color: var(--color-primary);
  color: #0A0A0A;
}

.badge-success {
  background-color: rgba(52, 211, 153, 0.2);
  color: var(--color-success);
}

.badge-warning {
  background-color: rgba(251, 191, 36, 0.2);
  color: var(--color-warning);
}

.badge-error {
  background-color: rgba(248, 113, 113, 0.2);
  color: var(--color-error);
}

/* Avatar */
.avatar {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-full);
  background-color: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-sm {
  width: 32px;
  height: 32px;
}

.avatar-lg {
  width: 64px;
  height: 64px;
}

/* Flex */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.gap-sm {
  gap: 4px;
}

.gap-md {
  gap: 8px;
}

.gap-lg {
  gap: 16px;
}

/* Spacing */
.mt-sm { margin-top: 4px; }
.mt-md { margin-top: 8px; }
.mt-lg { margin-top: 16px; }
.mt-xl { margin-top: 24px; }

.mb-sm { margin-bottom: 4px; }
.mb-md { margin-bottom: 8px; }
.mb-lg { margin-bottom: 16px; }
.mb-xl { margin-bottom: 24px; }

.p-sm { padding: 4px; }
.p-md { padding: 8px; }
.p-lg { padding: 16px; }
.p-xl { padding: 24px; }

/* Safe area */
.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  text-align: center;
}

.empty-state-icon {
  width: 64px;
  height: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-state-text {
  color: var(--color-text-secondary);
  font-size: 14px;
}

/* Loading */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.loading-spinner {
  width: 24px;
  height: 24px;
  border: 2px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
